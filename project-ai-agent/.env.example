# ===== DeepSeek 配置（推荐用于 AI Agent） =====
OPENAI_API_KEY_DEEPSEEK=your-deepseek-api-key-here
OPENAI_BASE_URL_DEEPSEEK=https://api.deepseek.com
MODEL_NAME_DEEPSEEK=deepseek-chat

# ===== OpenAI 配置 =====
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
MODEL_NAME=gpt-4o-mini

# ===== 搜索引擎（Tavily） =====
TAVILY_API_KEY=your-tavily-api-key-here

# ===== 网页爬取（Firecrawl） =====
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# ===== 后端 API 通信密钥 =====
BACKEND_API_KEY=your-backend-api-key-here

# ===== 数据库配置 =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/person_blog
REDIS_URL=redis://localhost:6379/2
ES_HOST=http://localhost:9200

# ===== 博客后端 API =====
BACKEND_API_BASE=http://localhost:8080/api

# ===== Nacos 服务发现 =====
NACOS_ENABLED=false
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_SERVICE_NAME=python-ai
NACOS_USERNAME=
NACOS_PASSWORD=


# ===== LangSmith 可观测性 =====
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=byteblog-agent-dev