# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=person_blog
DB_USERNAME=postgres
DB_PASSWORD=your-db-password-here

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DATABASE=2

# ===== RabbitMQ 配置 =====
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ===== Elasticsearch 配置 =====
ES_URIS=http://localhost:9200

# ===== JWT 配置 =====
JWT_SECRET=your-jwt-secret-key-here-at-least-64-characters-long

# ===== XXL-Job 配置 =====
XXL_JOB_ADMIN_ADDRESSES=http://localhost:8080/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=your-xxl-job-access-token-here
XXL_JOB_EXECUTOR_IP=
XXL_JOB_EXECUTOR_PORT=9999

# ===== 阿里云 OSS 配置 =====
OSS_ACCESS_KEY_ID=your-oss-access-key-id-here
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret-here
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME=your-bucket-name-here

# ===== OpenAI / Spring AI 配置 =====
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ===== Python AI 服务配置 =====
PYTHON_SERVICE_URL=http://127.0.0.1:8000

# ===== API Key 认证配置（内部服务间通信） =====
API_UNIVERSAL_KEY=your-secure-api-key-here
